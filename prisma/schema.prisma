// ── NextAuth (Auth.js) models — HAND-MAINTAINED, @map to the auth_* tables.
// Do NOT run `prisma db pull` without re-adding these: introspection would
// regenerate them as snake_case and break the adapter's expected field names.
model User {
  id            String    @id @default(uuid()) @db.Char(36)
  name          String?   @db.VarChar(255)
  email         String?   @unique @db.VarChar(255)
  emailVerified DateTime? @map("email_verified") @db.DateTime(6)
  image         String?   @db.VarChar(1024)
  passwordHash  String?   @map("password_hash") @db.VarChar(255)
  createdAt     DateTime  @default(now()) @map("created_at") @db.DateTime(6)
  accounts      Account[]
  sessions      Session[]

  @@map("auth_users")
}

model Account {
  id                String  @id @default(uuid()) @db.Char(36)
  userId            String  @map("user_id") @db.Char(36)
  type              String  @db.VarChar(255)
  provider          String  @db.VarChar(255)
  providerAccountId String  @map("provider_account_id") @db.VarChar(255)
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String? @db.VarChar(255)
  scope             String? @db.VarChar(255)
  id_token          String? @db.Text
  session_state     String? @db.VarChar(255)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Char(36)
  sessionToken String   @unique @map("session_token") @db.VarChar(255)
  userId       String   @map("user_id") @db.Char(36)
  expires      DateTime @db.DateTime(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String   @db.VarChar(255)
  token      String   @db.VarChar(255)
  expires    DateTime @db.DateTime(6)

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

// Per-vendor fulfillment of a (shared, storefront) order. An order can contain
// items from multiple vendors; each vendor dispatches its own slice. App-scoped
// by vendor_id (no FKs — kept additive/independent of the shared orders table).
model vendor_order_fulfillment {
  id              String    @id @db.Char(36)
  order_id        String    @db.Char(36)
  vendor_id       String    @db.Char(36)
  status          String    @default("PENDING") @db.VarChar(32)
  courier         String?   @db.VarChar(255)
  tracking_number String?   @db.VarChar(255)
  tracking_url    String?   @db.VarChar(1024)
  dispatched_at   DateTime? @db.DateTime(6)
  delivered_at    DateTime? @db.DateTime(6)
  notes           String?   @db.MediumText
  created_at      DateTime  @default(now()) @db.DateTime(6)
  updated_at      DateTime  @default(now()) @db.DateTime(6)

  @@unique([order_id, vendor_id], map: "uq_vof_order_vendor")
  @@index([vendor_id], map: "idx_vof_vendor")
  @@map("vendor_order_fulfillment")
}

// Per-vendor activity / audit trail (who changed what, when). Best-effort writes
// from the mutating endpoints; never blocks the operation. App-scoped by vendor_id.
model vendor_activity_log {
  id            String   @id @db.Char(36)
  vendor_id     String   @db.Char(36)
  actor_user_id String?  @db.Char(36)
  actor_email   String?  @db.VarChar(255)
  action        String   @db.VarChar(64)
  entity_type   String?  @db.VarChar(48)
  entity_id     String?  @db.Char(36)
  summary       String?  @db.VarChar(512)
  meta          Json?
  created_at    DateTime @default(now()) @db.DateTime(6)

  @@index([vendor_id, created_at], map: "idx_val_vendor_created")
  @@index([entity_type, entity_id], map: "idx_val_entity")
  @@map("vendor_activity_log")
}
