generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model brands {
  id                 String               @id @db.Char(36)
  slug               String               @unique @db.VarChar(255)
  name               String               @db.MediumText
  description        String?              @db.MediumText
  created_at         DateTime             @default(now()) @db.DateTime(6)
  thumbnail_path     String?              @db.MediumText
  thumbnail_url      String?              @db.MediumText
  active             Boolean              @default(true)
  position           Int                  @default(10)
  updated_at         DateTime             @default(now()) @db.DateTime(6)
  brand_code         String?              @unique(map: "brands_brand_code_idx") @db.VarChar(255)
  brand_translations brand_translations[]
  inventory_units    inventory_units[]
  products           products[]

  @@index([position])
}

model categories {
  id                    String                  @id @db.Char(36)
  slug                  String                  @unique @db.VarChar(255)
  name                  String                  @db.MediumText
  description           String?                 @db.MediumText
  parent_id             String?                 @db.Char(36)
  created_at            DateTime                @default(now()) @db.DateTime(6)
  updated_at            DateTime                @default(now()) @db.DateTime(6)
  categories            categories?             @relation("categoriesTocategories", fields: [parent_id], references: [id], onUpdate: NoAction, map: "categories_parent_fk")
  other_categories      categories[]            @relation("categoriesTocategories")
  category_translations category_translations[]
  products              products[]

  @@index([parent_id], map: "categories_parent_id_fkey")
}

model product_images {
  id           String   @id @db.Char(36)
  product_id   String   @db.Char(36)
  storage_path String   @db.VarChar(255)
  alt          String?  @db.MediumText
  sort_order   Int      @default(0)
  created_at   DateTime @default(now()) @db.DateTime(6)
  products     products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "product_images_product_fk")

  @@unique([product_id, storage_path], map: "product_images_unique_per_path")
  @@index([product_id], map: "product_images_product_idx")
  @@index([product_id, sort_order], map: "product_images_product_sort")
  @@index([sort_order], map: "product_images_sort_idx")
}

model products {
  id                             String                           @id @db.Char(36)
  sku                            String?                          @unique @db.VarChar(255)
  slug                           String                           @unique @db.VarChar(255)
  name                           String                           @db.VarChar(255)
  short_description              String?                          @db.MediumText
  description                    String?                          @db.MediumText
  brand                          String?                          @db.MediumText
  price                          Decimal?                         @db.Decimal(12, 2)
  currency                       String?                          @default("INR") @db.VarChar(512)
  country_of_origin              String?                          @db.MediumText
  volume_ml                      Decimal?                         @db.Decimal(10, 2)
  net_weight_g                   Decimal?                         @db.Decimal(10, 2)
  attributes                     Json                             @default(dbgenerated("(cast(_utf8mb4\\'{}\\' as json))"))
  category_id                    String                           @db.Char(36)
  hero_image_path                String?                          @db.MediumText
  is_published                   Boolean                          @default(true)
  created_at                     DateTime                         @default(now()) @db.DateTime(6)
  updated_at                     DateTime                         @default(now()) @db.DateTime(6)
  brand_id                       String?                          @db.Char(36)
  compare_at_price               Decimal?                         @db.Decimal(12, 2)
  sale_price                     Decimal?                         @db.Decimal(12, 2)
  vendor_price                   Decimal?                         @db.Decimal(12, 2)
  sale_starts_at                 DateTime?                        @db.DateTime(6)
  sale_ends_at                   DateTime?                        @db.DateTime(6)
  is_featured                    Boolean                          @default(false)
  is_trending                    Boolean                          @default(false)
  featured_rank                  Int?
  new_until                      DateTime?                        @db.DateTime(6)
  meta_title                     String?                          @db.MediumText
  meta_description               String?                          @db.MediumText
  og_image_path                  String?                          @db.MediumText
  views_count                    BigInt                           @default(0)
  purchases_count                BigInt                           @default(0)
  last_viewed_at                 DateTime?                        @db.DateTime(6)
  last_purchased_at              DateTime?                        @db.DateTime(6)
  deleted_at                     DateTime?                        @db.DateTime(6)
  vendor_id                      String?                          @db.Char(36)
  track_inventory                Boolean                          @default(true)
  stock_qty                      Int                              @default(0)
  ingredients_md                 String?                          @db.MediumText
  additional_details_md          String?                          @db.MediumText
  key_features_md                String?                          @db.MediumText
  faq                            Json                             @default(dbgenerated("(cast(_utf8mb4\\'[]\\' as json))"))
  key_benefits                   Json                             @default(dbgenerated("(cast(_utf8mb4\\'[]\\' as json))"))
  additional_details             Json                             @default(dbgenerated("(cast(_utf8mb4\\'{}\\' as json))"))
  made_in_korea                  Boolean                          @default(false)
  is_vegetarian                  Boolean                          @default(false)
  cruelty_free                   Boolean                          @default(false)
  toxin_free                     Boolean                          @default(false)
  paraben_free                   Boolean                          @default(false)
  video_path                     String?                          @db.MediumText
  promo_exempt                   Boolean                          @default(false)
  expiry_date                    DateTime?                        @db.Date
  product_code                   String?                          @unique(map: "products_product_code_idx") @db.VarChar(255)
  brand_code                     String?                          @db.MediumText
  hsn                            String?                          @db.MediumText
  box_contents_md                String?                          @db.MediumText
  is_bundle                      Boolean                          @default(false)
  gross_weight_g                 Decimal?                         @db.Decimal(8, 2)
  inventory_product_id           String?                          @db.Char(36)
  purchase_price                 Decimal                          @default(0.00) @db.Decimal(12, 2)
  cart_items                     cart_items[]
  home_influencer_video_products home_influencer_video_products[]
  home_product_video_products    home_product_video_products[]
  home_product_videos            home_product_videos[]
  influence_caps                 influence_caps?
  inventory_units                inventory_units[]
  invoice_batch_items            invoice_batch_items[]
  invoice_units                  invoice_units[]
  order_attribution_items        order_attribution_items[]
  order_items                    order_items[]
  product_country_prices         product_country_prices[]
  product_images                 product_images[]
  product_reviews                product_reviews[]
  product_story_blocks           product_story_blocks[]
  product_translations           product_translations[]
  product_videos                 product_videos[]
  brands                         brands?                          @relation(fields: [brand_id], references: [id], onUpdate: NoAction, map: "products_brand_fk")
  categories                     categories                       @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "products_category_fk")
  products                       products?                        @relation("productsToproducts", fields: [inventory_product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_inventory_self_fk")
  other_products                 products[]                       @relation("productsToproducts")
  vendors                        vendors?                         @relation(fields: [vendor_id], references: [id], onUpdate: NoAction)
  promo_codes                    promo_codes[]
  referral_links                 referral_links[]
  wishlist_items                 wishlist_items[]

  @@index([inventory_product_id], map: "idx_products_inventory_product")
  @@index([vendor_id, expiry_date], map: "idx_products_vendor_expiry_date")
  @@index([brand_id])
  @@index([category_id], map: "products_category_idx")
  @@index([featured_rank], map: "products_featured_idx")
  @@index([is_bundle])
  @@index([new_until])
  @@index([is_published, created_at], map: "products_pub_created_idx")
  @@index([is_trending], map: "products_trending_idx")
  @@index([vendor_id], map: "products_vendor_idx")
  @@fulltext([name, short_description, description], map: "products_ft")
}

model delete_debug {
  id     Int       @id @default(autoincrement())
  msg    String?   @db.MediumText
  constr String?   @db.MediumText
  ts     DateTime? @default(now()) @db.DateTime(6)

  @@map("_delete_debug")
}

model addresses {
  id                                              String     @id @db.Char(36)
  user_id                                         String     @db.Char(36)
  line1                                           String     @db.MediumText
  line2                                           String?    @db.MediumText
  city                                            String     @db.MediumText
  state                                           String     @db.MediumText
  pincode                                         String     @db.MediumText
  country                                         String     @default("India") @db.VarChar(512)
  is_default                                      Boolean    @default(false)
  created_at                                      DateTime   @default(now()) @db.DateTime(6)
  updated_at                                      DateTime   @default(now()) @db.DateTime(6)
  name                                            String?    @db.MediumText
  phone                                           String?    @db.MediumText
  email                                           String?    @db.MediumText
  landmark                                        String?    @db.MediumText
  profiles_addresses_user_idToprofiles            profiles   @relation("addresses_user_idToprofiles", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  orders                                          orders[]
  profiles_profiles_default_address_idToaddresses profiles[] @relation("profiles_default_address_idToaddresses")

  @@index([user_id], map: "addresses_default_unique")
  @@index([user_id], map: "addresses_user_idx")
}

model admin_notification_reads {
  notification_id     String              @db.Char(36)
  admin_id            String              @db.Char(36)
  read_at             DateTime            @default(now()) @db.DateTime(6)
  admin_notifications admin_notifications @relation(fields: [notification_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([notification_id, admin_id])
  @@index([admin_id], map: "idx_anr_admin_id")
}

model admin_notifications {
  id                       String                     @id @db.Char(36)
  type                     String                     @db.VarChar(255)
  title                    String                     @db.MediumText
  body                     String?                    @db.MediumText
  link                     String?                    @db.MediumText
  severity                 String                     @default("info") @db.VarChar(512)
  meta                     Json?
  created_at               DateTime                   @default(now()) @db.DateTime(6)
  created_by               String?                    @db.Char(36)
  admin_notification_reads admin_notification_reads[]

  @@index([created_at], map: "idx_admin_notifications_created_at")
  @@index([type], map: "idx_admin_notifications_type")
}

model app_admins {
  user_id    String   @id @db.Char(36)
  email      String?  @unique @db.VarChar(255)
  created_at DateTime @default(now()) @db.DateTime(6)
}

model banner_translations {
  id           String       @id @db.Char(36)
  banner_id    String       @db.Char(36)
  locale       String       @db.VarChar(255)
  title        String?      @db.MediumText
  alt          String?      @db.MediumText
  source_hash  String?      @db.MediumText
  source       String       @default("ai") @db.VarChar(512)
  created_at   DateTime     @default(now()) @db.DateTime(6)
  updated_at   DateTime     @default(now()) @db.DateTime(6)
  home_banners home_banners @relation(fields: [banner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([banner_id, locale])
  @@index([banner_id, locale], map: "banner_translations_lookup")
}

model batches {
  id                  String                @id @db.Char(36)
  batch_code          String                @unique @db.VarChar(255)
  product_id          String                @db.Char(36)
  quantity            Int
  start_date          DateTime              @db.Date
  expiry_date         DateTime              @db.Date
  status              String?               @default("IN_STOCK") @db.VarChar(512)
  created_at          DateTime?             @default(now()) @db.DateTime(6)
  updated_at          DateTime?             @default(now()) @db.DateTime(6)
  inventory_units     inventory_units[]
  invoice_batch_items invoice_batch_items[]
}

model brand_translations {
  id          String   @id @db.Char(36)
  brand_id    String   @db.Char(36)
  locale      String   @db.VarChar(255)
  description String?  @db.MediumText
  source_hash String?  @db.MediumText
  source      String   @default("ai") @db.VarChar(512)
  created_at  DateTime @default(now()) @db.DateTime(6)
  updated_at  DateTime @default(now()) @db.DateTime(6)
  brands      brands   @relation(fields: [brand_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([brand_id, locale])
  @@index([brand_id, locale], map: "brand_translations_lookup")
}

model campaign_posts {
  id                   String             @id @db.Char(36)
  campaign_id          String             @db.Char(36)
  instagram_account_id String             @db.Char(36)
  caption              String?            @db.MediumText
  media_type           String             @default("image") @db.VarChar(64)
  media_url            String?            @db.MediumText
  thumbnail_url        String?            @db.MediumText
  scheduled_at         DateTime?          @db.DateTime(6)
  published_at         DateTime?          @db.DateTime(6)
  status               String             @default("draft") @db.VarChar(64)
  instagram_media_id   String?            @db.MediumText
  permalink            String?            @db.MediumText
  error_message        String?            @db.MediumText
  created_at           DateTime?          @default(now()) @db.DateTime(6)
  updated_at           DateTime?          @default(now()) @db.DateTime(6)
  campaigns            campaigns          @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  instagram_accounts   instagram_accounts @relation(fields: [instagram_account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaign_id], map: "campaign_posts_campaign_id_fkey")
  @@index([instagram_account_id], map: "campaign_posts_instagram_account_id_fkey")
}

model campaigns {
  id                   String             @id @db.Char(36)
  owner_id             String             @db.Char(36)
  instagram_account_id String             @db.Char(36)
  name                 String             @db.MediumText
  description          String?            @db.MediumText
  status               String             @default("draft") @db.VarChar(64)
  start_date           DateTime?          @db.Date
  end_date             DateTime?          @db.Date
  created_at           DateTime?          @default(now()) @db.DateTime(6)
  updated_at           DateTime?          @default(now()) @db.DateTime(6)
  campaign_posts       campaign_posts[]
  instagram_accounts   instagram_accounts @relation(fields: [instagram_account_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  profiles             profiles           @relation(fields: [owner_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([instagram_account_id], map: "campaigns_instagram_account_id_fkey")
  @@index([owner_id], map: "campaigns_owner_id_fkey")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cart_items {
  id              String   @id @db.Char(36)
  cart_id         String   @db.Char(36)
  product_id      String   @db.Char(36)
  sku             String?  @db.MediumText
  name            String   @db.MediumText
  hero_image_path String?  @db.MediumText
  unit_price      Decimal  @db.Decimal(12, 2)
  mrp             Decimal? @db.Decimal(12, 2)
  quantity        Int      @default(1)
  line_total      Decimal  @db.Decimal(12, 2)
  created_at      DateTime @default(now()) @db.DateTime(6)
  updated_at      DateTime @default(now()) @db.DateTime(6)
  carts           carts    @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  products        products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cart_id, product_id], map: "cart_items_unique")
  @@index([cart_id], map: "cart_items_cart_idx")
  @@index([product_id], map: "cart_items_product_id_fkey")
}

model carts {
  id                    String       @id @db.Char(36)
  user_id               String       @unique(map: "carts_user_unique") @db.Char(36)
  currency              String       @default("INR") @db.VarChar(512)
  subtotal              Decimal      @default(0.00) @db.Decimal(12, 2)
  shipping_fee_estimate Decimal      @default(0.00) @db.Decimal(12, 2)
  discount_total        Decimal      @default(0.00) @db.Decimal(12, 2)
  total_estimate        Decimal      @default(0.00) @db.Decimal(12, 2)
  created_at            DateTime     @default(now()) @db.DateTime(6)
  updated_at            DateTime     @default(now()) @db.DateTime(6)
  cart_items            cart_items[]
  profiles              profiles     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "carts_user_idx")
}

model category_translations {
  id          String     @id @db.Char(36)
  category_id String     @db.Char(36)
  locale      String     @db.VarChar(255)
  name        String?    @db.MediumText
  description String?    @db.MediumText
  source_hash String?    @db.MediumText
  source      String     @default("ai") @db.VarChar(512)
  created_at  DateTime   @default(now()) @db.DateTime(6)
  updated_at  DateTime   @default(now()) @db.DateTime(6)
  categories  categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([category_id, locale])
  @@index([category_id, locale], map: "category_translations_lookup")
}

model contact_messages {
  id         BigInt   @id @default(autoincrement())
  name       String   @db.MediumText
  email      String   @db.MediumText
  phone      String?  @db.MediumText
  subject    String?  @db.MediumText
  message    String   @db.MediumText
  status     String   @default("new") @db.VarChar(512)
  created_at DateTime @default(now()) @db.DateTime(6)
}

model country_contacts {
  country_code    String   @id @db.VarChar(255)
  public_phone    String?  @db.MediumText
  whatsapp_number String?  @db.MediumText
  support_email   String?  @db.MediumText
  business_hours  String?  @db.MediumText
  public_address  String?  @db.MediumText
  is_active       Boolean  @default(true)
  updated_at      DateTime @default(now()) @db.DateTime(6)
  updated_by      String?  @db.Char(36)
  contact_name    String?  @db.MediumText

  @@index([country_code], map: "idx_country_contacts_active")
}

model country_shipping_rates {
  country       String   @id @db.VarChar(255)
  active        Boolean  @default(true)
  notes         String?  @db.MediumText
  created_at    DateTime @default(now()) @db.DateTime(6)
  updated_at    DateTime @default(now()) @db.DateTime(6)
  eta_days_min  Int?
  eta_days_max  Int?
  slab_500g_inr Decimal  @db.Decimal(10, 2)
  slab_1kg_inr  Decimal  @db.Decimal(10, 2)
  slab_2kg_inr  Decimal  @db.Decimal(10, 2)
  slab_3kg_inr  Decimal  @db.Decimal(10, 2)
  slab_5kg_inr  Decimal  @db.Decimal(10, 2)
  slab_7kg_inr  Decimal  @db.Decimal(10, 2)
  slab_10kg_inr Decimal  @db.Decimal(10, 2)
  slab_15kg_inr Decimal  @db.Decimal(10, 2)
  slab_20kg_inr Decimal  @db.Decimal(10, 2)

  @@index([active])
}

model currency_rates {
  code            String   @id @db.VarChar(255)
  name            String   @db.MediumText
  symbol          String   @db.MediumText
  decimals        Int      @default(2)
  rate_from_inr   Decimal  @db.Decimal(20, 6)
  active          Boolean  @default(true)
  last_updated_at DateTime @default(now()) @db.DateTime(6)
}

model customers {
  id                                                          String            @id @db.Char(36)
  vendor_id                                                   String            @db.Char(36)
  name                                                        String            @db.MediumText
  phone                                                       String?           @db.VarChar(255)
  email                                                       String?           @db.VarChar(255)
  address                                                     String?           @db.MediumText
  created_at                                                  DateTime          @default(now()) @db.DateTime(6)
  updated_at                                                  DateTime          @default(now()) @db.DateTime(6)
  vendors                                                     vendors           @relation(fields: [vendor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inventory_units_inventory_units_demo_customer_idTocustomers inventory_units[] @relation("inventory_units_demo_customer_idTocustomers")
  inventory_units_inventory_units_sold_customer_idTocustomers inventory_units[] @relation("inventory_units_sold_customer_idTocustomers")

  @@index([vendor_id, email], map: "customers_vendor_email_idx")
  @@index([vendor_id, email], map: "customers_vendor_email_unique")
  @@index([vendor_id])
  @@index([vendor_id, phone], map: "customers_vendor_phone_idx")
  @@index([vendor_id, phone], map: "customers_vendor_phone_unique")
}

model dtdc_api_logs {
  id             String          @id @db.Char(36)
  shipment_id    String?         @db.Char(36)
  api_name       String          @db.MediumText
  endpoint       String?         @db.MediumText
  request        Json?
  response       Json?
  http_status    Int?
  success        Boolean?
  created_at     DateTime        @default(now()) @db.DateTime(6)
  dtdc_shipments dtdc_shipments? @relation(fields: [shipment_id], references: [id], onUpdate: NoAction)

  @@index([created_at], map: "idx_dtdc_api_logs_created_at")
  @@index([shipment_id], map: "idx_dtdc_api_logs_shipment_id")
}

model dtdc_shipment_events {
  id             String         @id @db.Char(36)
  shipment_id    String         @db.Char(36)
  event_at       DateTime?      @db.DateTime(6)
  action         String?        @db.VarChar(255)
  status_code    String?        @db.MediumText
  origin         String?        @db.MediumText
  destination    String?        @db.MediumText
  remarks        String?        @db.MediumText
  raw            Json?
  created_at     DateTime       @default(now()) @db.DateTime(6)
  dtdc_shipments dtdc_shipments @relation(fields: [shipment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([shipment_id, event_at, action], map: "uniq_dtdc_events_dedup")
  @@index([event_at], map: "idx_dtdc_events_event_at")
  @@index([shipment_id], map: "idx_dtdc_events_shipment_id")
}

model dtdc_shipments {
  id                      String                 @id @db.Char(36)
  order_id                String                 @db.Char(36)
  reference_number        String?                @db.VarChar(255)
  customer_code           String?                @db.MediumText
  status                  String                 @default("draft") @db.VarChar(64)
  is_active               Boolean                @default(true)
  service_type_id         String?                @db.MediumText
  commodity_id            String?                @db.MediumText
  load_type               String?                @db.MediumText
  is_cod                  Boolean                @default(false)
  cod_amount              Decimal?               @db.Decimal(12, 2)
  weight_kg               Decimal?               @db.Decimal(10, 3)
  length_cm               Decimal?               @db.Decimal(10, 2)
  breadth_cm              Decimal?               @db.Decimal(10, 2)
  height_cm               Decimal?               @db.Decimal(10, 2)
  last_label_code         String?                @db.MediumText
  last_label_format       String?                @db.MediumText
  label_last_generated_at DateTime?              @db.DateTime(6)
  dtdc_request            Json?
  dtdc_response           Json?
  last_error              String?                @db.MediumText
  created_at              DateTime               @default(now()) @db.DateTime(6)
  updated_at              DateTime               @default(now()) @db.DateTime(6)
  last_polled_at          DateTime?              @db.DateTime(6)
  status_last_changed_at  DateTime?              @db.DateTime(6)
  dtdc_api_logs           dtdc_api_logs[]
  dtdc_shipment_events    dtdc_shipment_events[]
  orders                  orders                 @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([is_active, last_polled_at], map: "idx_dtdc_shipments_active_poll")
  @@index([order_id], map: "idx_dtdc_shipments_order_id")
  @@index([status], map: "idx_dtdc_shipments_status")
  @@index([order_id], map: "uniq_dtdc_shipments_active_order")
  @@index([reference_number], map: "uniq_dtdc_shipments_reference_number")
}

model dtdc_tracking_tokens {
  id         String    @id @db.Char(36)
  env        String    @db.VarChar(255)
  token      String    @db.MediumText
  expires_at DateTime? @db.DateTime(6)
  created_at DateTime  @default(now()) @db.DateTime(6)

  @@index([env], map: "idx_dtdc_tracking_tokens_env")
}

model email_campaign {
  id                       String                     @id @db.Char(36)
  subject                  String                     @db.MediumText
  body_html                String                     @db.MediumText
  target_type              String                     @db.VarChar(64)
  created_at               DateTime                   @default(now()) @db.DateTime(6)
  created_by               String?                    @db.Char(36)
  status                   String                     @default("draft") @db.VarChar(64)
  send_started_at          DateTime?                  @db.DateTime(6)
  send_completed_at        DateTime?                  @db.DateTime(6)
  email_campaign_category  email_campaign_category[]
  email_campaign_recipient email_campaign_recipient[]
  email_unsubscribe        email_unsubscribe[]

  @@index([created_at])
}

model email_campaign_category {
  campaign_id    String         @db.Char(36)
  category_id    String         @db.Char(36)
  email_campaign email_campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  email_category email_category @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([campaign_id, category_id])
  @@index([campaign_id], map: "email_campaign_category_campaign_idx")
  @@index([category_id], map: "email_campaign_category_category_idx")
}

model email_campaign_recipient {
  id                      String         @id @db.Char(36)
  campaign_id             String         @db.Char(36)
  contact_id              String?        @db.Char(36)
  email                   String         @db.MediumText
  name                    String?        @db.MediumText
  is_registered           Boolean        @default(false)
  status                  String         @default("pending") @db.VarChar(64)
  error                   String?        @db.MediumText
  sent_at                 DateTime?      @db.DateTime(6)
  ses_message_id          String?        @db.MediumText
  delivery_event          String?        @db.VarChar(64)
  delivery_event_at       DateTime?      @db.DateTime(6)
  delivery_event_payload  Json?
  has_opened              Boolean        @default(false)
  opened_at               DateTime?      @db.DateTime(6)
  has_clicked             Boolean        @default(false)
  clicked_at              DateTime?      @db.DateTime(6)
  last_engagement_payload Json?
  email_campaign          email_campaign @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  email_contact           email_contact? @relation(fields: [contact_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([campaign_id], map: "email_campaign_recipient_campaign_idx")
  @@index([contact_id], map: "email_campaign_recipient_contact_id_fkey")
  @@index([status])
}

model email_category {
  id                      String                    @id @db.Char(36)
  slug                    String                    @unique @db.VarChar(255)
  label                   String                    @db.MediumText
  description             String?                   @db.MediumText
  created_at              DateTime                  @default(now()) @db.DateTime(6)
  email_campaign_category email_campaign_category[]
  email_contact_category  email_contact_category[]
}

model email_change_requests {
  id              String    @id @db.Char(36)
  user_id         String    @db.Char(36)
  current_email   String    @db.MediumText
  requested_email String    @db.MediumText
  status          String    @default("pending") @db.VarChar(255)
  reason          String?   @db.MediumText
  admin_note      String?   @db.MediumText
  requested_at    DateTime  @default(now()) @db.DateTime(6)
  processed_at    DateTime? @db.DateTime(6)
  processed_by    String?   @db.Char(36)

  @@index([requested_at], map: "idx_ecr_requested_at")
  @@index([status], map: "idx_ecr_status")
  @@index([user_id], map: "idx_ecr_user_id")
}

model email_contact {
  id                       String                     @id @db.Char(36)
  email                    String                     @db.MediumText
  name                     String?                    @db.MediumText
  is_registered            Boolean                    @default(false)
  registered_user_id       String?                    @db.Char(36)
  created_at               DateTime                   @default(now()) @db.DateTime(6)
  source                   String?                    @default("manual") @db.VarChar(512)
  email_campaign_recipient email_campaign_recipient[]
  email_contact_category   email_contact_category[]
}

model email_contact_category {
  contact_id     String         @db.Char(36)
  category_id    String         @db.Char(36)
  email_category email_category @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  email_contact  email_contact  @relation(fields: [contact_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([contact_id, category_id])
  @@index([category_id], map: "email_contact_category_category_idx")
  @@index([contact_id], map: "email_contact_category_contact_idx")
}

model email_unsubscribe {
  id             String          @id @db.Char(36)
  email          String          @unique @db.VarChar(255)
  created_at     DateTime        @default(now()) @db.DateTime(6)
  source         String?         @default("user") @db.VarChar(512)
  campaign_id    String?         @db.Char(36)
  email_campaign email_campaign? @relation(fields: [campaign_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([campaign_id], map: "email_unsubscribe_campaign_id_fkey")
  @@index([email])
}

model email_verification_tokens {
  id         String    @id @db.Char(36)
  user_id    String    @db.Char(36)
  email      String    @db.MediumText
  token_hash String    @unique @db.VarChar(255)
  expires_at DateTime  @db.DateTime(6)
  used_at    DateTime? @db.DateTime(6)
  created_at DateTime  @default(now()) @db.DateTime(6)

  @@index([expires_at], map: "idx_evt_expires_at")
  @@index([used_at], map: "idx_evt_used_at")
  @@index([user_id], map: "idx_evt_user_id")
}

model events {
  id          String   @id @db.Char(36)
  occurred_at DateTime @default(now()) @db.DateTime(6)
  user_id     String?  @db.Char(36)
  anon_id     String   @db.VarChar(255)
  session_id  String   @db.VarChar(255)
  event_name  String   @db.VarChar(255)
  path        String?  @db.MediumText
  referrer    String?  @db.MediumText
  user_agent  String?  @db.MediumText
  ip_prefix   String?  @db.MediumText
  utm         Json?
  device      Json?
  props       Json     @default(dbgenerated("(cast(_utf8mb4\\'{}\\' as json))"))

  @@index([anon_id, occurred_at], map: "events_anon_time_idx")
  @@index([event_name, occurred_at], map: "events_name_time_idx")
  @@index([occurred_at])
  @@index([session_id], map: "events_session_idx")
  @@index([user_id, occurred_at], map: "events_user_time_idx")
}

model facebook_ads {
